# Base URL of the deployed MobiCova API (no trailing slash).
# Local dev falls back to http://localhost:4000/api/v1 when unset.
VITE_API_URL=https://your-api-host.example.com/api/v1

# --- Error tracking (optional but recommended for production) ---
# Sentry DSN for the browser app. Absent => disabled (friendly crash screen only,
# no reporting). Create a separate React project in Sentry and paste its DSN.
# NOTE: this is read at BUILD time — rebuild the client after changing it.
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0
