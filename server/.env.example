PORT=4000
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Optional — enables the live Claude triage assistant (rule-based fallback used if unset)
ANTHROPIC_API_KEY=
# Optional — override the triage model (defaults to claude-sonnet-4-5)
ANTHROPIC_MODEL=

# Optional — enables Stripe premium checkout (enrolment works without it)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

CLIENT_URL=http://localhost:5173
