PORT=4000
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# Optional — PEM CA certificate to verify the database's TLS cert (defence
# against MITM). Paste the full cert as one value. When unset, the connection is
# still encrypted but the cert is not verified (managed-Postgres default).
DATABASE_CA_CERT=
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Optional — enables the live Claude triage assistant (rule-based fallback used if unset)
ANTHROPIC_API_KEY=
# Optional — override the triage model (defaults to claude-sonnet-4-5)
ANTHROPIC_MODEL=

# Optional — enables Paystack premium checkout (NGN-native; preferred when set)
PAYSTACK_SECRET_KEY=

# Optional — enables Stripe premium checkout (fallback; enrolment works without it)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional — enables live WhatsApp member intake (Meta Cloud API). The USSD and
# WhatsApp simulators work without these; they only gate live WhatsApp replies.
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
# Meta App Secret — REQUIRED to accept inbound WhatsApp webhooks. The POST webhook
# verifies X-Hub-Signature-256 against this and rejects (401) when it's unset.
WHATSAPP_APP_SECRET=
# Shared token appended as ?token=... on the Africa's Talking USSD/voice callback
# URLs. When set, those webhooks require it (constant-time checked). Recommended in prod.
AT_WEBHOOK_TOKEN=
# Optional — MobiCova's OWN Slack channel (a Slack Incoming Webhook) for platform-ops
# signals: new org + distribution-partner sign-ups. Business events only, no PHI.
# (Per-tenant Slack is configured by each org in Settings → Notifications, not here.)
PLATFORM_SLACK_WEBHOOK_URL=

# Optional — Supabase Storage for claim documents (receipts, referral letters,
# scans). Set the project URL + a SERVICE ROLE key (server-side only — never ship
# it to the client) and a private bucket name. When unset, the Claims module
# still works; document upload is simply disabled.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=claim-documents

# Optional — member portal OTP login. When 'true' (or when no SMS/WhatsApp
# delivery channel is configured), the one-time code is returned in the API
# response and logged, so the passwordless flow is testable without a gateway.
# Set to anything but 'true' in a real deployment that can actually deliver codes.
OTP_DEV_MODE=

# Optional — password set for the demo accounts (admin + providers) by `npm run seed`.
# Set this to a private value so the demo password is never committed; defaults to
# a non-trivial built-in if unset. Re-running the seed rotates existing demo accounts.
DEMO_SEED_PASSWORD=

# Optional — comma-separated emails granted platform-admin access to the catalog
# Admin UI (manage insurance plans + partners). The seeded demo admin is elevated
# automatically; set this to grant access to your own account(s).
PLATFORM_ADMIN_EMAILS=

# Allowed browser origin(s) for CORS. Accepts a comma-separated list — the first
# is treated as the canonical origin (used for payment redirect URLs). Example:
#   CLIENT_URL=https://digitalhealth.mobicova.com,https://mobicova-client.onrender.com
CLIENT_URL=http://localhost:5173

# Public base URL of THIS API (no trailing slash). Used to derive the SAML SSO
# Service Provider identifiers (entityID, ACS callback, login URL) that partners
# register with their identity provider. In production set the externally
# reachable origin, e.g. https://mobicova-api.onrender.com
SERVER_URL=http://localhost:4000

# --- Error tracking & monitoring (optional but recommended for production) ---
# Sentry DSN for the API. Absent => error tracking disabled (console logging only).
# Create a Node/Express project in Sentry and paste its DSN here.
SENTRY_DSN=
# Environment tag shown in Sentry (e.g. production, staging). Defaults to NODE_ENV.
APP_ENV=production
# 0 = capture errors only (cheapest). Raise toward 1.0 to sample request traces.
SENTRY_TRACES_SAMPLE_RATE=0

# Migration guard. Default off: boot logs + /health warn about un-applied
# migrations. Set true to also make /readyz return 503 while any migration in the
# repo hasn't been applied — a hard guard against serving on a mismatched schema.
MIGRATIONS_STRICT=false

# Friendly sender for org-branded member welcome emails: the organisation name is
# the display name, this is the address (e.g. "AXA Mansard Health <org@mobicovahealth.com>").
# Must be on a RESEND-verified domain.
ORG_EMAIL_ALIAS=org@mobicovahealth.com
